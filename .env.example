# Example environment configuration (copy to .env and fill with your values)

# =============================================================================
# MySQL Database Configuration
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=changeme_user
MYSQL_PASSWORD=changeme_password
MYSQL_DATABASE=get_results

# =============================================================================
# Backend API (Data Ingestion)
# =============================================================================
BACKEND_API_URL=http://localhost:8081/api/ingest/matches
BACKEND_API_KEY=your_backend_api_key

# =============================================================================
# Source API (Competition List)
# =============================================================================
API_URL=http://localhost:8081/api/competitions
API_KEY=your_source_api_key

# =============================================================================
# Scraper Configuration (Optional)
# =============================================================================
# SCRAPER_MAX_WORKERS=3           # Parallel workers (1-10)
# SCRAPER_RATE_LIMIT_DELAY=1.0    # Delay between requests in seconds
# SCRAPER_REQUEST_TIMEOUT=15      # HTTP timeout in seconds

# =============================================================================
# Application (Optional)
# =============================================================================
# DEBUG=false
# LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR, CRITICAL
